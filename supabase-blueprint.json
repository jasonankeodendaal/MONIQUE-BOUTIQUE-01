{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A client order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order_number": { "type": "string" },
        "client_id": { "type": "string" },
        "status": { "type": "string" },
        "items": { "type": "array" },
        "total_amount": { "type": "number" },
        "shipping_address": { "type": "string" },
        "tracking_number": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "order_number", "client_id", "status", "items", "total_amount", "created_at", "updated_at"]
    },
    "Product": {
      "title": "Product",
      "description": "A catalog item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category_id": { "type": "string" },
        "subcategory_id": { "type": "string" },
        "media": { "type": "array" },
        "tags": { "type": "array" },
        "created_at": { "type": "string" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Site configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "seoOgImage": { "type": "string" },
        "enableSchemaMarkup": { "type": "boolean" },
        "schemaType": { "type": "string" },
        "customSchemaJson": { "type": "string" },
        "localBusinessName": { "type": "string" },
        "localBusinessAddress": { "type": "string" },
        "localBusinessPhone": { "type": "string" },
        "localBusinessOpeningHours": { "type": "string" },
        "localBusinessCountry": { "type": "string" },
        "localBusinessLat": { "type": "number" },
        "localBusinessLng": { "type": "number" },
        "localBusinessWebsite": { "type": "string" },
        "localBusinessCategory": { "type": "string" },
        "robotsGeneratedAt": { "type": "number" },
        "sitemapGeneratedAt": { "type": "number" },
        "robotsStatus": { "type": "string" },
        "sitemapStatus": { "type": "string" },
        "seoAutoCleanUrls": { "type": "boolean" },
        "seoEnableLazyLoading": { "type": "boolean" },
        "seoRequireAltText": { "type": "boolean" },
        "seoAutoRelatedProducts": { "type": "boolean" },
        "seoForceHttps": { "type": "boolean" },
        "seoEnableCanonicalTags": { "type": "boolean" },
        "seoShowLastUpdated": { "type": "boolean" },
        "googleAnalyticsId": { "type": "string" },
        "googleTagManagerId": { "type": "string" },
        "facebookPixelId": { "type": "string" },
        "tiktokPixelId": { "type": "string" },
        "pinterestTagId": { "type": "string" },
        "amazonAssociateId": { "type": "string" },
        "webhookUrl": { "type": "string" },
        "categoryCardStyle": { "type": "string" },
        "navStyle": { "type": "string" },
        "gscVerificationId": { "type": "string" },
        "customHeaderScripts": { "type": "string" },
        "customFooterScripts": { "type": "string" },
        "emailJsServiceId": { "type": "string" },
        "emailJsTemplateId": { "type": "string" },
        "emailJsPublicKey": { "type": "string" }
      }
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Administrator user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "array" },
        "created_at": { "type": "number" }
      }
    },
    "Client": {
      "title": "Client",
      "description": "Registered client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "number" }
      }
    }
  },
  "supabase": {
    "orders": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Client orders"
    },
    "products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Product catalog"
    },
    "categories": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "settings": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Site settings"
    },
    "admin_users": {
      "schema": { "$ref": "#/entities/AdminUser" },
      "description": "Administrator users"
    },
    "clients": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Registered clients"
    }
  }
}
